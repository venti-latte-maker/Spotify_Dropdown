<Window x:Class="Spotify_DropDown.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="150" 
        Width="400"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False">
    <StackPanel Margin="15">
        <TextBlock
            x:Name="SongTitle"
            Text="Bohemian Rhapsody"
            FontSize="16"
            FontWeight="Bold"/>
        <TextBlock
            x:Name="ArtistName"
            Text="Queen"/>
        <WrapPanel Margin="0, 10">
            <Button
                x:Name="PrevButton"
                Content="⏮"
                Width="50"/>
            <Button
                x:Name="PlayPauseButton"
                Content="▶"
                Width="50"/>
            <Button
                x:Name="NextButton"
                Content="⏭"
                Width="50"/>
            <Button
                x:Name="LoginButton"
                Content="Login to Spotify"
                Width="150"/>
        </WrapPanel>
        <Slider
            x:Name="VolumeSlider"
            Minimum="0"
            Maximum="100"
            Width="150"/>
    </StackPanel>
 
</Window>
